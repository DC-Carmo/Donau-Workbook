    {name:'Rhino & Lion',type:'Mid Field Scrum',detail:['RHINO (Right)','8 to 9','12 unders to fix inside','Out the back to 10','14 as outside option','LION (Left)','9 takes easy space left','Fix Opp 10','13 to 10','Pop to 15 or straight to 11'],diagram:'Mid Field Scrum.png'},

  ], 

