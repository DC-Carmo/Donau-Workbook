const lo80 = [ 

  {name:'L — Alpha',sub:'80/70 Formation',detail:'1 and 6 lift 4 at the front. Alpha: 5 arrives last and rushes forward to lift 4.'}, 

  {name:'N — Dummy L',sub:'80/70 Formation',detail:'Dummy L with 1 going past and lifting 6.'}, 

  {name:'E — Forward Move',sub:'80/70 — Trigger 4 (163)',detail:'Dummy L as 5 moves forward inside 3/6 (1 step dummy and back), then 3 lifts 5.'}, 

  {name:'O — Back Move',sub:'80/70 — Trigger 4 (653)',detail:'Dummy L, 5 goes one step forward and up lifted by 3 and 8.'}, 

  {name:'U — Counter',sub:'80/70 — Trigger 4 (387)',detail:'Dummy N as 5 moves back to 8, then 8 and 7 slide past 5 to 3. 3 and 7 lift 8.'}, 

  {name:'T — Tail',sub:'80/70 — Trigger 4 (587)',detail:'Dummy L as 5 moves back to 8, 8 is lifted by 5 and 7.'}, 

  {name:'CAT — Front',sub:'All Formations',detail:'Throw to the front man. Used when space is clear at front.'}, 

  {name:'I — No Jump',sub:'80/70 — Trigger 2 (4)',detail:'No jump — throw directly to 4 without a lift.'}, 

]; 

const lo50 = [ 

  {name:'L — Front Lift',sub:'50 Formation — Trigger 4 (145)',detail:'4 lifted at front by 1 and 5. Alpha: 5 arrives last and rushes forward to lift 4.'}, 

  {name:'O — Back Lift',sub:'50 Formation — Trigger 8 (458)',detail:'4 turns and lifts 5 with 8. Zulu: 5 arrives last and rushes back to lift 8.'}, 

  {name:'U — Counter',sub:'50 Formation — Trigger 5 (483)',detail:'Dummy T: 5 moves back to 8, 8 and 3 slide past 5 to 4. 4 and 3 lift 8.'}, 

  {name:'T — Tail',sub:'50 Formation — Trigger 4 (583)',detail:'4 fakes forward to 1. At the same time 5 comes back to lift 8 with 3.'}, 

  {name:'L — 40 Front',sub:'40 Formation — Trigger 4 (145)',detail:'4 lifted at front by 1 and 5. Alpha same as L. Zulu same as O.'}, 

  {name:'E — Dummy O',sub:'40 Formation — Trigger 4 (158)',detail:'Dummy O: as 4 comes back, 5 and 8 move to 1.'}, 

  {name:'O — 40 Back',sub:'40 Formation — Trigger 2 (458)',detail:'4 and 8 lift 5 off the standard 40 setup.'}, 

]; 

function buildLoCalls(){ 

  document.getElementById('loCalls80').innerHTML = lo80.map(c=>`

    <div class="lo-call" onclick="toggleLo(this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleLo(this);}" tabindex="0" role="button" aria-expanded="false">

      <div class="lc-name">${c.name}</div>

      <div class="lc-sub">${c.sub}</div>

      <div class="lc-detail">${c.detail}</div>

    </div>

  `).join('');

  document.getElementById('loCalls50').innerHTML = lo50.map(c=>`

    <div class="lo-call" onclick="toggleLo(this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleLo(this);}" tabindex="0" role="button" aria-expanded="false">

      <div class="lc-name">${c.name}</div>

      <div class="lc-sub">${c.sub}</div>

      <div class="lc-detail">${c.detail}</div>

    </div>

  `).join(''); 

} 

function toggleLo(el){

  const was = el.classList.contains('active');

  document.querySelectorAll('.lo-call').forEach(e=>{e.classList.remove('active');e.setAttribute('aria-expanded','false');});

  if(!was){el.classList.add('active');el.setAttribute('aria-expanded','true');}

} 

buildLoCalls(); 

 

