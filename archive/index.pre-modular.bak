function setCategory(cat,btn){

  document.querySelectorAll('.zone-btn').forEach(b=>{b.classList.remove('active');b.setAttribute('aria-selected','false');});

  btn.classList.add('active');
  btn.setAttribute('aria-selected','true');

  const container = document.getElementById('attackContent');

  const items = attackData[cat]||[];

  container.innerHTML = items.map((p,i)=>`

    <div class="play-list-item" onclick="togglePlay(this)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();togglePlay(this);}" tabindex="0" role="button" aria-expanded="false" data-i="${i}">

      <div class="play-name">${p.name}</div>

      <div class="play-type">${p.type}</div>

      <div class="play-detail">

        <ul>${p.detail.map(d=>`<li>${d}</li>`).join('')}</ul>

        ${p.diagram ? `<button class="diagram-btn" onclick="event.stopPropagation();openFieldLightbox('${p.diagram}','${p.name}')" onkeydown="event.stopPropagation();">View Diagram</button>` : ''}

      </div>

    </div>

  `).join('');

} 

function togglePlay(el){

  const wasActive = el.classList.contains('active');

  document.querySelectorAll('.play-list-item').forEach(e=>{e.classList.remove('active');e.setAttribute('aria-expanded','false');});

  if(!wasActive){el.classList.add('active');el.setAttribute('aria-expanded','true');}

} 

setCategory('setpiece', document.querySelector('.zone-btn.active')); 

 

