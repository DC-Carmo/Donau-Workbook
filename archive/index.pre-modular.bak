    {name:'Ramp 2 — Right',type:'Exit from Lineout Right',detail:['Phase 1: 9 to 8, 14/12/8/7 to breakdown, 10 stays in pocket','Phase 2: Sickles stay on right side','9 back to 10 to kick out or option to shift left with numbers']}, 

  ], 

